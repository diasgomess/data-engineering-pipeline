# App database (used by pipeline tasks)
DB_HOST=host.docker.internal
DB_PORT=5432
DB_NAME=engenharia_dados
DB_USER=postgres
DB_PASSWORD=change_me

# Airflow metadata database (postgres-airflow service)
AIRFLOW_POSTGRES_USER=airflow
AIRFLOW_POSTGRES_PASSWORD=change_me
AIRFLOW_POSTGRES_DB=airflow

# Airflow admin user (created by airflow-init)
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=change_me
AIRFLOW_ADMIN_FIRSTNAME=Admin
AIRFLOW_ADMIN_LASTNAME=User
AIRFLOW_ADMIN_ROLE=Admin
AIRFLOW_ADMIN_EMAIL=admin@example.com
